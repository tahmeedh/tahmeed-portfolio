---
import { resumeData } from '../data/resume';
---

<section id="about" class="relative py-32 px-6 md:px-12 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/2 -translate-y-1/2 right-0 w-[600px] h-[600px] bg-purple-600/5 rounded-full blur-3xl" />
  </div>

  <div class="max-w-7xl mx-auto relative z-10">
    <div class="grid lg:grid-cols-2 gap-16 items-start">
      <!-- Left: Bio -->
      <div class="space-y-8">
        <div>
          <p class="text-purple-400 text-sm font-mono tracking-widest mb-3">// ABOUT ME</p>
          <h2 class="text-4xl md:text-5xl font-bold text-white leading-tight">
            Building quality<br />at the speed of AI.
          </h2>
        </div>

        <p class="text-gray-400 text-lg leading-relaxed">
          {resumeData.bio}
        </p>

        <p class="text-gray-500 leading-relaxed">
          Based in {resumeData.location}, I've helped companies like Global Relay and Encorp ship
          reliable software to hundreds of thousands of users — from migrating legacy test suites to
          training computer vision models that inspect 4,000+ items with 90%+ accuracy.
        </p>

        <!-- Education -->
        <div class="border border-white/8 rounded-2xl p-5 bg-white/[0.02]">
          <div class="flex items-center gap-3 mb-2">
            <div class="w-8 h-8 bg-purple-500/10 rounded-lg flex items-center justify-center">
              <svg class="w-4 h-4 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14l9-5-9-5-9 5 9 5z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
              </svg>
            </div>
            <div>
              <p class="text-white font-medium text-sm">{resumeData.education.school}</p>
              <p class="text-gray-500 text-xs">{resumeData.education.degree} · GPA {resumeData.education.gpa} · {resumeData.education.year}</p>
            </div>
          </div>
        </div>

        <!-- Awards -->
        <div class="space-y-2">
          {resumeData.awards.map((award) => (
            <div class="flex items-center gap-3">
              <span class="text-yellow-500 text-sm">★</span>
              <span class="text-gray-400 text-sm">{award.title} — {award.position} <span class="text-gray-600">({award.year})</span></span>
            </div>
          ))}
        </div>

        <!-- Links -->
        <div class="flex gap-3 pt-2">
          <a
            href={resumeData.links.github}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 px-4 py-2.5 border border-white/10 hover:border-purple-500/50 rounded-xl text-sm text-gray-300 hover:text-white transition-all duration-200 bg-white/[0.02] hover:bg-purple-500/5"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            GitHub
          </a>
          <a
            href={resumeData.links.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 px-4 py-2.5 border border-white/10 hover:border-blue-500/50 rounded-xl text-sm text-gray-300 hover:text-white transition-all duration-200 bg-white/[0.02] hover:bg-blue-500/5"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
        </div>
      </div>

      <!-- Right: Skills grid -->
      <div class="space-y-6">
        <div>
          <p class="text-gray-500 text-xs font-mono tracking-widest mb-4">// TECHNICAL SKILLS</p>
          <div class="space-y-5">
            {Object.entries(resumeData.skills).map(([category, items]) => (
              <div>
                <p class="text-xs text-purple-400/70 font-mono uppercase tracking-wider mb-2.5">{category.replace('_', ' ')}</p>
                <div class="flex flex-wrap gap-2">
                  {items.map((skill: string) => (
                    <span class="text-xs px-2.5 py-1.5 rounded-lg bg-white/[0.04] border border-white/8 text-gray-300 hover:border-purple-500/30 hover:text-purple-300 transition-colors duration-200 font-mono">
                      {skill}
                    </span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Certifications -->
        <div class="border-t border-white/5 pt-5">
          <p class="text-gray-500 text-xs font-mono tracking-widest mb-3">// CERTIFICATIONS</p>
          <div class="flex flex-wrap gap-2">
            {resumeData.certifications.map((cert) => (
              <span class="text-xs px-3 py-1.5 rounded-full border border-green-500/20 text-green-400/70 bg-green-500/5">
                ✓ {cert}
              </span>
            ))}
          </div>
        </div>

        <!-- Experience timeline preview -->
        <div class="border-t border-white/5 pt-5">
          <p class="text-gray-500 text-xs font-mono tracking-widest mb-4">// TIMELINE</p>
          <div class="relative pl-4 space-y-4">
            <div class="absolute left-0 top-1 bottom-1 w-px bg-gradient-to-b from-purple-500/50 via-blue-500/30 to-transparent" />
            {resumeData.experience.slice(0, 3).map((exp) => (
              <div class="relative">
                <div class="absolute -left-[17px] top-1.5 w-2 h-2 rounded-full bg-purple-500 border-2 border-dark-800" />
                <div>
                  <p class="text-white text-sm font-medium">{exp.company}</p>
                  <p class="text-gray-500 text-xs">{exp.role}</p>
                  <p class="text-purple-400/60 text-xs font-mono mt-0.5">{exp.period}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
