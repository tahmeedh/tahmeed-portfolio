---
import { resumeData } from '../data/resume';
---

<section id="contact" class="relative py-32 px-6 md:px-12 overflow-hidden">
  <!-- Background glow -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-purple-500/20 to-transparent" />
    <div class="absolute bottom-1/3 left-1/2 -translate-x-1/2 w-[500px] h-[500px] bg-purple-600/8 rounded-full blur-3xl" />
  </div>

  <div class="max-w-4xl mx-auto relative z-10 text-center">
    <p class="text-purple-400 text-sm font-mono tracking-widest mb-4">// GET IN TOUCH</p>
    <h2 class="text-4xl md:text-6xl font-bold text-white mb-6 leading-tight">
      Let's build something<br />
      <span class="bg-clip-text text-transparent" style="background-image: linear-gradient(135deg, #a855f7, #3b82f6);">
        remarkable.
      </span>
    </h2>
    <p class="text-gray-400 text-lg max-w-xl mx-auto mb-12 leading-relaxed">
      Open to senior SDET, AI testing, and security automation roles. Also happy to discuss
      consulting, freelance automation work, or just chat about testing at scale.
    </p>

    <!-- Primary CTA -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
      <a
        href={`mailto:${resumeData.email}`}
        class="group relative inline-flex items-center gap-2 px-8 py-4 rounded-2xl font-semibold text-white overflow-hidden transition-all duration-300 hover:scale-[1.02] active:scale-[0.98]"
        style="background: linear-gradient(135deg, #a855f7, #3b82f6)"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        Send an email
      </a>
      <a
        href={resumeData.links.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-4 rounded-2xl font-semibold text-gray-300 hover:text-white border border-white/10 hover:border-purple-500/40 bg-white/[0.02] hover:bg-purple-500/5 transition-all duration-300 hover:scale-[1.02] active:scale-[0.98]"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        Connect on LinkedIn
      </a>
    </div>

    <!-- Contact details grid -->
    <div class="grid sm:grid-cols-3 gap-4 max-w-2xl mx-auto">
      <div class="p-4 rounded-2xl border border-white/8 bg-white/[0.02]">
        <p class="text-gray-600 text-xs font-mono mb-1">EMAIL</p>
        <p class="text-gray-300 text-sm">{resumeData.email}</p>
      </div>
      <div class="p-4 rounded-2xl border border-white/8 bg-white/[0.02]">
        <p class="text-gray-600 text-xs font-mono mb-1">LOCATION</p>
        <p class="text-gray-300 text-sm">Vancouver, BC</p>
      </div>
      <div class="p-4 rounded-2xl border border-white/8 bg-white/[0.02]">
        <p class="text-gray-600 text-xs font-mono mb-1">AVAILABILITY</p>
        <div class="flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 bg-green-400 rounded-full" />
          <p class="text-green-400 text-sm">Open to work</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="border-t border-white/5 py-8 px-6 md:px-12">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
    <span class="font-mono text-gray-600 text-sm">© 2025 Tahmeed Hossain</span>
    <div class="flex items-center gap-6">
      <a href={resumeData.links.github} target="_blank" rel="noopener noreferrer" class="text-gray-600 hover:text-gray-400 text-sm transition-colors font-mono">GitHub</a>
      <a href={resumeData.links.linkedin} target="_blank" rel="noopener noreferrer" class="text-gray-600 hover:text-gray-400 text-sm transition-colors font-mono">LinkedIn</a>
      <a href={`mailto:${resumeData.email}`} class="text-gray-600 hover:text-gray-400 text-sm transition-colors font-mono">Email</a>
    </div>
    <span class="text-gray-700 text-xs font-mono">Built with Astro · Spline · Claude API</span>
  </div>
</footer>
