---
import { resumeData } from '../data/resume';
---

<section id="works" class="relative py-32 px-6 md:px-12 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-purple-500/20 to-transparent" />
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-blue-500/10 to-transparent" />
  </div>

  <div class="max-w-7xl mx-auto relative z-10">
    <div class="mb-16 flex flex-col md:flex-row md:items-end justify-between gap-4">
      <div>
        <p class="text-purple-400 text-sm font-mono tracking-widest mb-3">// SELECTED WORKS</p>
        <h2 class="text-4xl md:text-5xl font-bold text-white leading-tight">
          Things I've built.
        </h2>
      </div>
      <a
        href={resumeData.links.github}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-gray-400 hover:text-purple-400 transition-colors font-mono flex items-center gap-2"
      >
        View all on GitHub →
      </a>
    </div>

    <!-- Projects grid -->
    <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-5">
      {resumeData.projects.map((project, i) => (
        <div
          class="group relative p-6 rounded-2xl bg-white/[0.02] border border-white/8 hover:border-purple-500/30 transition-all duration-300 hover:bg-purple-500/[0.03] cursor-default"
          style={`animation: fadeUp 0.5s ease-out ${i * 0.08}s both`}
        >
          <!-- Year badge -->
          <span class="absolute top-4 right-4 text-xs text-gray-600 font-mono">{project.year}</span>

          <!-- Icon -->
          <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-purple-600/20 to-blue-600/20 border border-purple-500/20 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-5 h-5 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
            </svg>
          </div>

          <h3 class="text-white font-semibold text-base mb-2 leading-snug group-hover:text-purple-300 transition-colors">
            {project.name}
          </h3>
          <p class="text-gray-500 text-sm leading-relaxed mb-4">
            {project.description}
          </p>

          <!-- Tags -->
          <div class="flex flex-wrap gap-1.5">
            {project.tags.map((tag: string) => (
              <span class="text-xs px-2 py-0.5 rounded-md bg-white/5 text-gray-500 font-mono border border-white/5 group-hover:border-purple-500/20 group-hover:text-purple-400/70 transition-colors">
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Experience section within Works -->
    <div class="mt-20">
      <p class="text-gray-500 text-xs font-mono tracking-widest mb-8">// PROFESSIONAL EXPERIENCE</p>
      <div class="space-y-4">
        {resumeData.experience.map((exp, i) => (
          <details class="group border border-white/8 rounded-2xl bg-white/[0.02] hover:border-purple-500/20 transition-colors duration-200 overflow-hidden">
            <summary class="flex items-center justify-between p-5 cursor-pointer list-none">
              <div class="flex items-center gap-4">
                <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-purple-600/20 to-blue-600/20 border border-purple-500/20 flex items-center justify-center text-xs text-purple-400 font-bold font-mono">
                  {String(i + 1).padStart(2, '0')}
                </div>
                <div>
                  <p class="text-white font-medium">{exp.company}</p>
                  <p class="text-gray-500 text-sm">{exp.role}</p>
                </div>
              </div>
              <div class="flex items-center gap-4">
                <span class="text-xs text-gray-600 font-mono hidden md:block">{exp.period}</span>
                <svg class="w-4 h-4 text-gray-500 group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </div>
            </summary>
            <div class="px-5 pb-5 border-t border-white/5">
              <p class="text-xs text-gray-600 font-mono mt-4 mb-3 md:hidden">{exp.period}</p>
              <ul class="space-y-2">
                {exp.highlights.map((h: string) => (
                  <li class="flex items-start gap-2 text-sm text-gray-400">
                    <span class="text-purple-500 mt-0.5 shrink-0">→</span>
                    <span>{h}</span>
                  </li>
                ))}
              </ul>
            </div>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>
